{
  "name": "orchestero-elements",
  "version": "0.0.1",
  "description": "Orchestero's shadcn-compatible component registry.",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.10",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/khanhduyvt0101/orchestero-elements.git"
  },
  "scripts": {
    "dev": "next dev --port 3717",
    "build": "bun run typecheck && next build --experimental-build-mode compile && next build --experimental-build-mode generate",
    "start": "next start",
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "registry:generate": "bun scripts/generate-registry.mjs",
    "registry:build": "bun run registry:generate && shadcn build registry.json --output public/r/styles/default",
    "registry:validate": "bun run registry:generate && shadcn registry validate registry.json",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "postcss": "^8.5.16"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@shadcn/react": "^0.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-resizable-panels": "^4.12.1",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^7.0.2"
  }
}
